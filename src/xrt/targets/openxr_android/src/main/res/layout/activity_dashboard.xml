    DisplayXR runtime diagnostics dashboard (#558) — the launcher screen.
    On-device equivalent of `displayxr-cli info` + `selftest`, plus live
    service state and the Android permission fragments hosted as cards.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:fillViewport="true"
    tools:context=".DashboardActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: logo + name + version + flavor badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imageLogo"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@string/logo_text"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/displayxr_logo" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6"
                    tools:text="DisplayXR" />

                <TextView
                    android:id="@+id/textVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/monado_lib_version"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body2" />

                <TextView
                    android:id="@+id/textFlavor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                    tools:text="out-of-process runtime" />
            </LinearLayout>
        </LinearLayout>

        <!-- Query progress / error line -->
        <LinearLayout
            android:id="@+id/rowQueryStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ProgressBar
                android:id="@+id/progressQuery"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/textQueryStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/diag_querying"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2" />
        </LinearLayout>

        <!-- Self-test -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSelftest"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_selftest" />

                <TextView
                    android:id="@+id/textSelftestVerdict"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                    android:textStyle="bold"
                    tools:text="PASS" />

                <TextView
                    android:id="@+id/textSelftestChecks"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Runtime -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRuntime"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_runtime" />

                <TextView
                    android:id="@+id/textRuntime"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Active plug-in -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardPlugin"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_plugin" />

                <TextView
                    android:id="@+id/textPlugin"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Display -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDisplay"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_display" />

                <TextView
                    android:id="@+id/textDisplay"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Rendering modes advertised by the DP -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardModes"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_modes" />

                <TextView
                    android:id="@+id/textModes"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Eye tracking -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardEyeTracking"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_eye_tracking" />

                <TextView
                    android:id="@+id/textEyeTracking"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Live service state (out-of-process flavor only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardLive"
            style="@style/DashboardCard"
            android:visibility="gone">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_live" />

                <TextView
                    android:id="@+id/textLive"
                    style="@style/DashboardCardMono" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Android status: VR listener + overlay permission fragments -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAndroid"
            style="@style/DashboardCard">

            <LinearLayout style="@style/DashboardCardBody">

                <TextView
                    style="@style/DashboardCardTitle"
                    android:text="@string/diag_card_android" />

                <FrameLayout
                    android:id="@+id/statusFrame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <FrameLayout
                    android:id="@+id/drawOverOtherAppsFrame"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnRefresh"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/diag_btn_refresh" />

            <Button
                android:id="@+id/btnCopyJson"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/diag_btn_copy" />

            <Button
                android:id="@+id/btnShare"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/diag_btn_share" />
        </LinearLayout>

        <Button
            android:id="@+id/btnShutdown"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/diag_btn_shutdown"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
