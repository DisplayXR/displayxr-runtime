;
; Exported symbols of DisplayXRClient.dll. The Khronos OpenXR loader
; calls xrNegotiateLoaderRuntimeInterface. The remaining symbols are
; the runtime DLL's aux export surface consumed by vendor plug-in DLLs
; via the import library DisplayXRClient.lib. See
; docs/adr/ADR-019-vendor-plugin-aux-boundary.md for the per-symbol
; rationale; the headers under src/xrt/auxiliary/util/ carry the
; XRT_API_FUNC decoration that mirrors this list on the import side.

EXPORTS
    ; --- Khronos OpenXR loader interface ---
    xrNegotiateLoaderRuntimeInterface

